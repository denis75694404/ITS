<script>
var tipoLabels = {
  salud: {label:'Establ. de Salud', bg:'#E6F1FB', color:'#042C53'},
  mercado: {label:'Mercado', bg:'#FAEEDA', color:'#412402'},
  educacion: {label:'Institución Educativa', bg:'#EAF3DE', color:'#173404'},
  parque: {label:'Parque / Plaza', bg:'#E1F5EE', color:'#04342C'}
};

function mostrarInfo(el) {
  var nombre = el.getAttribute('data-nombre');
  var desc = el.getAttribute('data-desc');
  var tipo = el.getAttribute('data-tipo');
  var t = tipoLabels[tipo] || {label:tipo, bg:'#eee', color:'#333'};
  document.getElementById('panelNombre').textContent = nombre;
  document.getElementById('panelDesc').textContent = desc;
  var pill = document.getElementById('panelTipo');
  pill.textContent = t.label;
  pill.style.background = t.bg;
  pill.style.color = t.color;
  document.getElementById('infoPanel').style.display = 'block';
}

function cerrarPanel() {
  document.getElementById('infoPanel').style.display = 'none';
}

function filtrar(tipo) {
  document.querySelectorAll('#filtros button').forEach(function(b){
    b.style.background = 'var(--color-background-primary)';
    b.style.color = 'var(--color-text-primary)';
  });
  var btn = document.querySelector('#filtros [data-f="'+tipo+'"]');
  if (btn) { btn.style.background='var(--color-text-primary)'; btn.style.color='var(--color-background-primary)'; }

  document.querySelectorAll('.punto').forEach(function(p){
    var ptipo = p.getAttribute('data-tipo');
    p.style.opacity = (tipo === 'todos' || ptipo === tipo) ? '1' : '0.15';
    p.style.pointerEvents = (tipo === 'todos' || ptipo === tipo) ? 'auto' : 'none';
  });

  cerrarPanel();
}
</script>

