<script>
var anos = [2018,2019,2020,2021,2022,2023,2024];
var anosAll = [2018,2019,2020,2021,2022,2023,2024,2025];
var vihTotal = [450,605,472,703,552,575,456,50];
var sidaTotal = [112,114,77,142,117,134,102,4];

var distritos = {
  'El Agustino': { tia:[1.06,1.43,0.53,0.89,1.04,0.98,1.17], riesgo:'alto', color:'#C0152A' },
  'Santa Anita':  { tia:[0.84,0.66,0.48,0.98,0.69,0.99,0.76], riesgo:'moderado', color:'#E8601C' },
  'Cieneguilla':  { tia:[0.00,0.60,0.00,1.00,0.25,0.98,1.39], riesgo:'moderado', color:'#F5A623' },
  'Chaclacayo':   { tia:[1.38,0.00,0.00,0.22,0.00,0.43,0.22], riesgo:'bajo', color:'#1E7B46' },
  'Ate':          { tia:[0.37,0.45,0.54,0.70,0.37,0.45,0.25], riesgo:'bajo', color:'#1A4A8A' },
  'Lurigancho':   { tia:[0.50,0.30,0.08,0.24,0.27,0.26,0.13], riesgo:'bajo', color:'#7B68EE' },
  'La Molina':    { tia:[0.23,0.05,0.06,0.18,0.30,0.06,0.24], riesgo:'bajo', color:'#4ECDC4' }
};

var scores = {
  'El Agustino':91, 'Santa Anita':74, 'Cieneguilla':62,
  'Chaclacayo':45, 'Ate':44, 'Lurigancho':28, 'La Molina':18
};

var paleta = ['#C0152A','#E8601C','#F5A623','#1E7B46','#1A4A8A','#7B68EE','#4ECDC4'];

function promedio(arr) {
  var s = 0;
  for (var i=0;i<arr.length;i++) s += arr[i];
  return (s/arr.length).toFixed(2);
}

// CHART 1: Tendencia
var ctxT = document.getElementById('chartTendencia').getContext('2d');
var chartTend = new Chart(ctxT, {
  type: 'bar',
  data: {
    labels: anosAll,
    datasets: [
      {
        label: 'Casos VIH',
        data: vihTotal,
        backgroundColor: 'rgba(26,74,138,0.75)',
        borderColor: '#1A4A8A',
        borderWidth: 1,
        borderRadius: 4,
        order: 2
      },
      {
        label: 'Eventos SIDA',
        data: sidaTotal,
        type: 'line',
        borderColor: '#C0152A',
        backgroundColor: 'rgba(192,21,42,0.1)',
        borderWidth: 2.5,
        pointBackgroundColor: '#C0152A',
        pointRadius: 4,
        tension: 0.3,
        fill: false,
        order: 1
      }
    ]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { position:'top', labels:{ font:{size:11}, boxWidth:14 } },
      tooltip: { mode:'index' }
    },
    scales: {
      x: { grid:{display:false}, ticks:{font:{size:11}} },
      y: { beginAtZero:true, grid:{color:'#EEF0F6'}, ticks:{font:{size:11}} }
    }
  }
});

function filtrarTendencia(btn, tipo) {
  document.querySelectorAll('.year-btn').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  if (tipo === 'todos') {
    chartTend.data.datasets[0].hidden = false;
    chartTend.data.datasets[1].hidden = false;
  } else if (tipo === 'vih') {
    chartTend.data.datasets[0].hidden = false;
    chartTend.data.datasets[1].hidden = true;
  } else {
    chartTend.data.datasets[0].hidden = true;
    chartTend.data.datasets[1].hidden = false;
  }
  chartTend.update();
}

// CHART 2: TIA por distrito
var ctxTIA = document.getElementById('chartTIA').getContext('2d');
var chartTIA = null;

function construirTIA(filtro) {
  var datasets = [];
  var nombres = Object.keys(distritos);
  if (filtro === 'Todos') {
    for (var i=0; i<nombres.length; i++) {
      var n = nombres[i];
      var d = distritos[n];
      datasets.push({
        label: n,
        data: d.tia,
        borderColor: paleta[i],
        backgroundColor: paleta[i] + '22',
        borderWidth: n === 'El Agustino' ? 3 : 1.5,
        pointRadius: n === 'El Agustino' ? 5 : 3,
        tension: 0.3,
        fill: false
      });
    }
  } else {
    var d2 = distritos[filtro];
    datasets.push({
      label: filtro,
      data: d2.tia,
      borderColor: d2.color,
      backgroundColor: d2.color + '22',
      borderWidth: 3,
      pointRadius: 5,
      pointBackgroundColor: d2.color,
      tension: 0.3,
      fill: true
    });
  }
  if (chartTIA) { chartTIA.destroy(); }
  chartTIA = new Chart(ctxTIA, {
    type: 'line',
    data: { labels: anos, datasets: datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position:'bottom', labels:{ font:{size:10}, boxWidth:12, padding:8 } },
        tooltip: {
          mode: 'index',
          callbacks: {
            label: function(ctx) { return ctx.dataset.label + ': ' + ctx.parsed.y.toFixed(2); }
          }
        }
      },
      scales: {
        x: { grid:{display:false}, ticks:{font:{size:11}} },
        y: {
          beginAtZero: true,
          grid: { color:'#EEF0F6' },
          ticks: { font:{size:11} },
          title: { display:true, text:'TIA × 10,000 hab.', font:{size:10} }
        }
      }
    }
  });
}
construirTIA('Todos');

function verDistrito(btn, nombre) {
  document.querySelectorAll('#tabsDistrito .tab').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  construirTIA(nombre);
}

// CHART 3: Transmisión
var ctxTr = document.getElementById('chartTransmision').getContext('2d');
new Chart(ctxTr, {
  type: 'doughnut',
  data: {
    labels: ['Sexual (94.6%)', 'Desconocido (4.8%)', 'Vertical (0.5%)', 'Parenteral (0.1%)'],
    datasets: [{
      data: [3656, 186, 18, 3],
      backgroundColor: ['#1A4A8A','#F5A623','#E8601C','#1E7B46'],
      borderWidth: 2,
      borderColor: '#fff',
      hoverOffset: 10
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    cutout: '62%',
    plugins: {
      legend: { position:'right', labels:{ font:{size:10}, boxWidth:13, padding:9 } },
      tooltip: {
        callbacks: {
          label: function(ctx) { return ctx.label + ': ' + ctx.parsed.toLocaleString() + ' casos'; }
        }
      }
    }
  }
});

// CHART 4: Sexo
var ctxS = document.getElementById('chartSexo').getContext('2d');
new Chart(ctxS, {
  type: 'bar',
  data: {
    labels: ['Masculino', 'Femenino'],
    datasets: [{
      data: [3172, 691],
      backgroundColor: ['#1A4A8A', '#E8601C'],
      borderRadius: 6,
      borderWidth: 0
    }]
  },
  options: {
    indexAxis: 'y',
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { display:false },
      tooltip: {
        callbacks: {
          label: function(ctx) {
            var pct = ctx.dataIndex === 0 ? '82.1%' : '17.9%';
            return ctx.parsed.x.toLocaleString() + ' casos (' + pct + ')';
          }
        }
      }
    },
    scales: {
      x: { beginAtZero:true, grid:{color:'#EEF0F6'}, ticks:{font:{size:10}} },
      y: { grid:{display:false}, ticks:{font:{size:11}} }
    }
  }
});

// RANKING
var rankData = Object.entries(scores).sort(function(a,b){ return b[1]-a[1]; });
var rankContainer = document.getElementById('rankList');
rankData.forEach(function(item, i) {
  var nombre = item[0];
  var score = item[1];
  var d = distritos[nombre];
  var prom = promedio(d.tia);
  var isTop = i === 0;
  var riesgoTxt = d.riesgo === 'alto' ? '🔴 Alto riesgo' : d.riesgo === 'moderado' ? '🟡 Riesgo moderado' : '🟢 Bajo riesgo';
  var div = document.createElement('div');
  div.className = 'rank-item' + (isTop ? ' top1' : '');
  div.innerHTML =
    '<div class="rank-num ' + (i < 2 ? 'top' : '') + '">' + (i+1) + '</div>' +
    '<div class="rank-info">' +
      '<div class="rank-name">' + nombre + (isTop ? ' ⭐' : '') + '</div>' +
      '<div class="rank-detail">TIA promedio: ' + prom + ' · ' + riesgoTxt + '</div>' +
    '</div>' +
    '<div class="rank-score" style="color:' + paleta[i] + '">' + score + '/100</div>';
  rankContainer.appendChild(div);
});

// TABLA
var tbody = document.getElementById('tablaDistritos');
var distOrdenados = Object.entries(distritos).sort(function(a,b){
  return parseFloat(promedio(b[1].tia)) - parseFloat(promedio(a[1].tia));
});
distOrdenados.forEach(function(item) {
  var nombre = item[0];
  var d = item[1];
  var prom = promedio(d.tia);
  var rCls = d.riesgo === 'alto' ? 'risk-alto' : d.riesgo === 'moderado' ? 'risk-moderado' : 'risk-bajo';
  var rTxt = d.riesgo === 'alto' ? 'Alto' : d.riesgo === 'moderado' ? 'Moderado' : 'Bajo';
  var isBest = nombre === 'El Agustino';
  var tr = document.createElement('tr');
  if (isBest) tr.style.background = '#fef2f3';
  var tds = d.tia.map(function(v) {
    var color = v >= 1 ? '#C0152A' : v >= 0.7 ? '#E8601C' : v >= 0.4 ? '#B45309' : '#5A6480';
    var fw = v >= 0.8 ? '700' : '400';
    return '<td style="color:' + color + ';font-weight:' + fw + '">' + v.toFixed(2) + '</td>';
  }).join('');
  tr.innerHTML =
    '<td style="font-weight:700">' + (isBest ? '★ ' : '') + nombre + '</td>' +
    tds +
    '<td style="font-weight:700">' + prom + '</td>' +
    '<td><span class="risk-pill ' + rCls + '">' + rTxt + '</span></td>';
  tbody.appendChild(tr);
});

// SCORE CARDS
var scoreContainer = document.getElementById('scoreCards');
rankData.forEach(function(item, i) {
  var nombre = item[0];
  var score = item[1];
  var d = distritos[nombre];
  var prom = promedio(d.tia);
  var isTop = nombre === 'El Agustino';
  var color = paleta[i];
  var riesgoUp = d.riesgo.charAt(0).toUpperCase() + d.riesgo.slice(1);
  var div = document.createElement('div');
  div.style.cssText = 'padding:14px;border-radius:12px;border:' + (isTop ? '2px solid ' + color : '1px solid #DDE3EE') + ';background:' + (isTop ? '#fef2f3' : '#fafbfd') + ';';
  div.innerHTML =
    '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">' +
      '<div style="font-weight:700;font-size:0.87rem;">' + (isTop ? '⭐ ' : '') + nombre + '</div>' +
      '<div style="font-size:1.25rem;font-weight:800;color:' + color + ';">' + score + '</div>' +
    '</div>' +
    '<div class="score-bar-wrap">' +
      '<div class="score-bar-bg"><div class="score-bar-fill" style="width:' + score + '%;background:' + color + ';"></div></div>' +
      '<div class="score-num" style="color:' + color + ';">/100</div>' +
    '</div>' +
    '<div style="margin-top:8px;font-size:0.7rem;color:#5A6480;">TIA prom: <strong>' + prom + '</strong> · Riesgo: <strong style="color:' + color + ';">' + riesgoUp + '</strong></div>';
  scoreContainer.appendChild(div);
});
</script>

</div>

