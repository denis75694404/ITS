function buildSim(){
  var h='';
  preguntas.forEach(function(p,i){
    h+='<div class="sim-q">'+
      '<span style="flex:1;">'+(i+1)+'. '+p.txt+'</span>'+
      '<div class="sim-radios">'+
        '<label><input type="radio" name="p'+i+'" value="si"> Sí</label>'+
        '<label><input type="radio" name="p'+i+'" value="no"> No</label>'+
      '</div></div>';
  });
  var el=document.getElementById('sim-preguntas');
  if(el) el.innerHTML=h;
}

function calcTriaje(){
  var score=0,all=true;
  preguntas.forEach(function(p,i){
    var v=document.querySelector('input[name="p'+i+'"]:checked');
    if(!v){all=false;}else if(v.value==='si'){score+=p.si;}
  });
  var res=document.getElementById('sim-resultado');
  if(!all){
    res.style.display='block';res.style.background='#FAEEDA';res.style.color='#412402';
    res.innerHTML='<strong>Completa todas las preguntas para ver el resultado.</strong>';return;
  }
  var ruta,bg,color,desc;
  if(score>=3){ruta='🔵 Ruta A — Flujo completo';bg='#E6F1FB';color='#0a2060';desc='Factores de riesgo identificados. Flujo: M1 → M2 → M3 → M5.';}
  else if(score>0){ruta='🔵 Ruta A — Flujo completo';bg='#E6F1FB';color='#0a2060';desc='Riesgo leve detectado. Se recomienda flujo completo: M1 → M2 → M3 → M5.';}
  else{ruta='🟢 Ruta C — Solo insumos';bg='#EAF3DE';color='#0a3010';desc='Sin factores de riesgo. Derivar a Mesa 4 para material preventivo.';}
  res.style.display='block';res.style.background=bg;res.style.color=color;
  res.innerHTML='<div style="font-weight:600;font-size:13px;margin-bottom:4px;">'+ruta+'</div>'+
    '<div style="font-size:12px;opacity:.85;">Puntaje: '+score+' pts. '+desc+'</div>';
}

function resetTriaje(){
  preguntas.forEach(function(p,i){
    document.querySelectorAll('input[name="p'+i+'"]').forEach(function(r){r.checked=false;});
  });
  var res=document.getElementById('sim-resultado');
  if(res) res.style.display='none';
}

